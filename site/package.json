{
  "name": "site",
  "version": "0.0.1",
  "scripts": {
    "check": "deno run -A npm:svelte-kit sync && deno run -A npm:svelte-check --tsconfig ./tsconfig.json",
    "dev": "deno run --allow-all npm:vite dev",
    "build": "deno run --allow-all npm:vite build",
    "preview": "deno run --allow-all npm:vite preview"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "bulma": "^1.0.4",
    "chart.js": "^4.5.1",
    "sass": "^1.94.2",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "vite": "^8.0.9"
  },
  "type": "module"
}
